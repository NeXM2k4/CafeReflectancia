# Copia este archivo como .streamlit/secrets.toml y completa tus valores.
# .streamlit/secrets.toml NO debe compartirse ni subirse a un repositorio publico.
#
# Como obtener bot_token:
#   1. En Telegram, busca a "@BotFather" y enviale /newbot
#   2. Sigue las instrucciones (nombre del bot, username terminado en "bot")
#   3. BotFather te da un token con forma "123456789:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
#
# Como obtener chat_id (tu propio chat con el bot):
#   1. Busca tu bot recien creado en Telegram y enviale cualquier mensaje (ej. "hola")
#   2. Abre en el navegador: https://api.telegram.org/bot<TU_TOKEN>/getUpdates
#   3. Busca en la respuesta JSON el campo "chat":{"id": ...} y copia ese numero

[telegram]
bot_token = "123456789:REEMPLAZA_CON_TU_TOKEN"
chat_id = "REEMPLAZA_CON_TU_CHAT_ID"
